// DELETE RECIPIENT (KEEP ONLY ONE COPY - THIS ONE)
app.delete('/api/recipients/:email', (req, res) => {
  const { email } = req.params;
  db.run(`DELETE FROM recipients WHERE email = ?`, [email], function(err) {
    if (err) {
      return res.status(500).json({ error: err.message });
    }
    // Also delete associated clicks
    db.run(`DELETE FROM clicks WHERE email = ?`, [email]);
    res.json({ success: true, message: 'Recipient deleted successfully' });
  });
});

// START THE SERVER

const PORT = 3000;
app.listen(PORT, () => {
  console.log(`Server running at http://localhost:${PORT}`);
  console.log(`View results at http://localhost:${PORT}/dashboard`);
  console.log(`View JSON data at http://localhost:${PORT}/results`);
  console.log('\nTo send emails, run: node send.js');
});

